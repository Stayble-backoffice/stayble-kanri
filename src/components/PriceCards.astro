---
import { pricePlans, requiredPriceNotes } from "../data/site";
---

<div class="desktop-price-plans">
  <div class="fee-formula" aria-label="管理費の計算式">
    <div class="formula-row">
      <span class="formula-eq">管理費</span>
      <span class="formula-symbol">=</span>
      <span class="formula-chip formula-fixed">物件規模別の月額固定費</span>
      <span class="formula-symbol">+</span>
      <span class="formula-chip formula-rate">売上歩合5%</span>
    </div>
  </div>

  <div class="price-cards">
    {pricePlans.map((plan) => (
      <article class="price-plan-card">
        <div class="plan-topline">
          <p class="pill">{plan.name}</p>
          <span>{plan.tag}</span>
        </div>
        <h3>{plan.range}</h3>
        <p class="plan-for">{plan.bestFor}</p>
        <div class="plan-price-grid" aria-label={`${plan.name}の管理費内訳`}>
          <div>
            <span>月額固定費</span>
            <strong>{plan.fixed}</strong>
          </div>
          <div>
            <span>売上歩合</span>
            <strong>{plan.commission}</strong>
          </div>
        </div>
        <p class="price-line">{plan.price}</p>
        {plan.note && <p class="plan-note">{plan.note}</p>}
      </article>
    ))}
  </div>
  <ul class="notes">
    {requiredPriceNotes.map((note) => <li>{note}</li>)}
  </ul>
</div>

<div class="mobile-price-plans mobile-only" aria-label="スマートフォン向け管理費プラン">
  <div class="mobile-fee-key">
    <span>管理費</span>
    <strong>月額固定費 + 売上5%</strong>
    <small>清掃費・リネンサプライ費などの実費は別途</small>
  </div>
  <div class="mobile-plan-stack">
    {pricePlans.map((plan) => (
      <article class="mobile-plan-card">
        <div>
          <span>{plan.name}</span>
          <h3>{plan.range}</h3>
        </div>
        <dl>
          <div>
            <dt>固定</dt>
            <dd>{plan.fixed.replace("月額", "")}</dd>
          </div>
          <div>
            <dt>歩合</dt>
            <dd>{plan.commission}</dd>
          </div>
        </dl>
        <p>{plan.bestFor}</p>
      </article>
    ))}
  </div>
  <details class="mobile-note-box">
    <summary>料金の注釈を見る</summary>
    <ul>
      {requiredPriceNotes.map((note) => <li>{note}</li>)}
    </ul>
  </details>
</div>
