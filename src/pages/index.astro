---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import ComparisonChart from "../components/ComparisonChart.astro";
import FAQList from "../components/FAQList.astro";
import HeroVisual from "../components/HeroVisual.astro";
import PriceCards from "../components/PriceCards.astro";
import SectionHeading from "../components/SectionHeading.astro";
import AreaShowcase from "../components/AreaShowcase.astro";
import { pageMeta, switchingFlow } from "../data/site";

const meta = pageMeta.home;
const problems = [
  {
    title: "管理費が高い",
    text: "売上に対する管理費が重く、管理費・清掃費の控除後に残る金額が思ったより残らない。"
  },
  {
    title: "清掃品質が安定しない",
    text: "管理会社が清掃を外注しているため、現場品質が見えづらい。"
  },
  {
    title: "リネンサプライや備品の運用が面倒",
    text: "リネンサプライ手配、備品補充、鍵の受け渡しなど、細かな現場業務が積み重なる。"
  },
  {
    title: "現地対応だけ欲しい",
    text: "フル代行まではいらない。でも、いざという時に現地対応してくれる先は必要。"
  }
];

const reasons = [
  {
    title: "清掃品質まで責任を持てる",
    text: "管理会社が清掃を外注するのではなく、Staybleが清掃・リネンサプライまでセットで対応します。"
  },
  {
    title: "リネンサプライまで標準対応",
    text: "リネンサプライを探す手間なく、物件特性に合わせてリネンサプライ運用を設計します。"
  },
  {
    title: "OTA立ち上げも無料",
    text: "既存OTAの引き継ぎではなく、Stayble側で新しく運用環境を整えます。"
  },
  {
    title: "現地対応は固定料金制",
    text: "駆け付け対応は固定料金制。対応後は、解決状況にかかわらずオーナー様へ報告します。"
  }
];

const services = [
  "清掃・リネンサプライのセット運用",
  "OTA掲載内容の整備・メッセージ対応",
  "宿泊者名簿・本人確認の運用支援",
  "簡易的な価格調整・カレンダー調整",
  "通常8:00〜22:00の現地対応",
  "定期報告・報告書対応"
];
---

<BaseLayout title={meta.title} description={meta.description} path={meta.path}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">STAYBLE SWITCHING MANAGEMENT</p>
        <h1>今の管理会社、<br />高すぎませんか？<br />清掃会社が管理を<br />請け負う時代へ。</h1>
        <p class="hero-copy">
          開業済み民泊のための、乗り換え民泊管理。管理費は月額5,000円〜 + 売上5%。清掃・リネンサプライ・OTA運用・現地対応まで、Staybleがまとめて支えます。
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/contact/">無料相談する</a>
          <a class="btn btn-secondary" href="/pricing/">料金シミュレーションを見る</a>
        </div>
        <ul class="hero-badges">
          <li>管理費 月額5,000円〜 + 売上5%</li>
          <li>初期費用0円</li>
          <li>写真撮影0円</li>
          <li>OTA初期立ち上げ0円</li>
          <li>清掃・リネンサプライはStaybleセット</li>
          <li>札幌市中心に対応</li>
        </ul>
      </div>
      <HeroVisual />
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <SectionHeading
        label="PROBLEM"
        title="その管理費、本当に必要ですか？"
        lead="民泊運営に必要なのは、見栄えのいい管理会社ではなく、清掃・リネンサプライ・現地対応がきちんと回ること。それなのに、毎月の管理費だけが重くなっていませんか？"
      />
      <div class="grid-4 desktop-card-grid">
        {problems.map((item, index) => (
          <article class="card">
            <span class="number">{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
      <div class="mobile-insight-list mobile-only">
        {problems.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        label="PRICE"
        title="管理費は、月額5,000円〜 + 売上5%。"
        lead="Staybleの管理費は、物件規模別の月額固定費と売上歩合5%で構成されます。清掃・リネンサプライを自社基盤で持つから、余計な管理コストを抑えた運用が可能です。"
      />
      <PriceCards />
      <div class="button-row">
        <a class="btn btn-primary" href="/pricing/">料金ページで詳しく見る</a>
      </div>
    </div>
  </section>

  <section class="section section-muted" id="simulation">
    <div class="container">
      <SectionHeading
        label="SIMULATION"
        title="管理費と清掃費が変わると、残る金額は変わります。"
        lead="同じ売上でも、管理費と清掃費の設計が違えば、管理控除後に残る金額は変わります。Staybleでは、現在の管理費・清掃費と比較しながら乗り換え後を試算できます。"
      />
      <ComparisonChart />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        label="WHY STAYBLE"
        title="なぜ清掃会社が管理を請け負えるのか。"
        lead="民泊運営でレビューを左右するのは、清掃・リネンサプライ・備品・現地対応です。Staybleはそこをすでに持っているから、管理会社としても余計な中間コストを抑えられます。"
      />
      <div class="grid-4 desktop-card-grid">
        {reasons.map((item, index) => (
          <article class="card">
            <span class="number">{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
      <div class="mobile-insight-list mobile-only">
        {reasons.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section feature-band">
    <div class="container split desktop-service-split">
      <div>
        <p class="section-label">SERVICE</p>
        <h2>清掃・リネンサプライ・OTA運用・現地対応まで、開業済み物件の運用に必要な範囲をまとめます。</h2>
        <p>
          開業支援ではなく、すでに運用中の民泊に必要な管理へ特化。過剰なフル代行ではなく、現場が回ることを重視します。
        </p>
        <div class="button-row">
          <a class="btn btn-secondary" href="/services/">サービス内容を見る</a>
        </div>
      </div>
      <div class="grid-2">
        {services.map((item) => (
          <article class="card">
            <h3>{item}</h3>
          </article>
        ))}
      </div>
    </div>
    <div class="container mobile-service-summary mobile-only">
      <p class="section-label">SERVICE</p>
      <h2>運用中物件に必要な業務だけを、現場基盤でまとめます。</h2>
      <ul>
        {services.slice(0, 5).map((item) => <li>{item}</li>)}
      </ul>
      <a class="btn btn-secondary" href="/services/">サービス内容を見る</a>
    </div>
  </section>

  <section class="section">
    <div class="container split desktop-cleaning-split">
      <div>
        <p class="section-label">CLEANING & LINEN SUPPLY</p>
        <h2>清掃品質まで責任を持つため、清掃・リネンサプライはStaybleセット契約です。</h2>
        <p>
          1部屋1名の個人制、定型写真報告、抜き打ちチェックで品質を追跡。民泊清掃管理約240室、年間清掃約15,000件の現場実績をもとに運用します。
        </p>
        <a class="btn btn-secondary" href="/cleaning-linen/">清掃・リネンサプライを見る</a>
      </div>
      <div class="card">
        <h3>現場運用の基盤</h3>
        <ul class="check-list">
          <li>1部屋1名の個人制で責任範囲を明確化</li>
          <li>清掃指示・進捗・写真報告をシステムで一元管理</li>
          <li>物件特性に応じたリネンサプライ方式を設計</li>
          <li>消耗品管理は任意オプションとして対応</li>
        </ul>
      </div>
    </div>
    <div class="container mobile-service-summary mobile-only">
      <p class="section-label">CLEANING & LINEN SUPPLY</p>
      <h2>清掃・リネンサプライはStaybleセット契約です。</h2>
      <ul>
        <li>民泊清掃管理 約240室</li>
        <li>年間清掃 約15,000件</li>
        <li>定型写真報告と品質チェック</li>
        <li>物件特性に応じたリネンサプライ方式</li>
      </ul>
      <a class="btn btn-secondary" href="/cleaning-linen/">清掃・リネンサプライを見る</a>
    </div>
  </section>

  <section class="section section-muted" id="area">
    <div class="container">
      <AreaShowcase />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading label="FLOW" title="乗り換えの流れ" lead="無料相談から運用開始まで、現在の管理会社・OTA・清掃状況を確認しながら進めます。" />
      <div class="flow-list desktop-flow-list">
        {switchingFlow.map((step, index) => (
          <article class="card flow-card">
            <span class="number">{String(index + 1).padStart(2, "0")}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
      <div class="mobile-flow-list mobile-only">
        {switchingFlow.map((step, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <SectionHeading label="FAQ" title="よくある質問" lead="乗り換え前に確認されやすい内容をまとめています。" />
      <FAQList limit={4} />
      <div class="button-row">
        <a class="btn btn-secondary" href="/faq/">FAQをすべて見る</a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
